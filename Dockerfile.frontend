# Multi-stage: Build React-App, dann mit Nginx ausliefern
FROM node:20-alpine AS builder

WORKDIR /app

# Build-Argument für API-Basis-URL (vom Browser aus erreichbar)
ARG VITE_API_URL=
ENV VITE_API_URL=$VITE_API_URL

COPY package.json ./
RUN npm install

COPY . .
RUN npm run build

# Production: Nginx mit statischen Dateien
FROM nginx:1.27-alpine

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Copy custom nginx config with security headers
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy built frontend
COPY --from=builder /app/dist /usr/share/nginx/html

# Run nginx as non-root (nginx:alpine supports this via the www-data user for workers,
# but the master process requires root to bind port 80.
# Use nginxinc/nginx-unprivileged image for fully rootless operation on port 8080.)
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
