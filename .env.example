# Datenschutzagent – Beispiel-Konfiguration
# Kopieren nach .env und anpassen.

# ---- Datenbank (wird in Docker Compose für Backend überschrieben) ----
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/datenschutzagent

# ---- Ollama (extern gehostet, z. B. im lokalen Netzwerk) ----
# Basis-URL des Ollama-Servers (vom Backend-Container aus erreichbar).
# Lokaler Host: host.docker.internal (Docker Desktop) oder IP des Rechners im LAN.
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Modell für Inferenz (z. B. llama3.2, mistral, codellama)
OLLAMA_MODEL=llama3.2
# Timeout für LLM-Anfragen in Sekunden
OLLAMA_TIMEOUT_SECONDS=120
# Ollama-Funktionen ein-/ausschalten
OLLAMA_ENABLED=true

# OCR für gescannte PDFs (Ollama Vision, z. B. qwen2.5-vl, minicpm-v)
# OLLAMA_OCR_MODEL=qwen2.5-vl
# OLLAMA_OCR_ENABLED=true
# OCR_MIN_CHARS_PER_PAGE=50
# OCR_DPI=150

# ---- CORS (kommagetrennt; Frontend-URLs, inkl. LAN-Zugriff) ----
# Wenn Sie das Frontend per LAN-IP aufrufen (z. B. http://192.168.1.20:3001), diese Origin hier ergänzen.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://192.168.1.20:3001,http://192.168.1.20:5173

# ---- Frontend Build: API-URL (für Browser-Aufrufe zum Backend) ----
# Wird nur beim Bau des Frontend-Images genutzt (docker compose build frontend).
# VITE_API_URL=http://localhost:8000

# ---- Celery (asynchrone Dokument-Extraktion) ----
# Broker-URL für Celery (Redis). Wenn leer oder CELERY_ENABLED=false: Extraktion beim Upload synchron.
# In Docker wird CELERY_BROKER_URL durch docker-compose gesetzt (redis://redis:6379/0).
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_ENABLED=true

# ---- Optional: Aktueller User (ohne OIDC) ----
# UUID des Users, der für GET/PATCH /me verwendet wird. Nur wenn OIDC_ENABLED=false.
# CURRENT_USER_ID=00000000-0000-4000-8000-000000000001

# ---- OAuth2/OIDC (Authentifizierung) ----
# Wenn OIDC_ENABLED=true, sind geschützte Routen nur mit gültigem Bearer-Token erreichbar.
# OIDC_ISSUER_URL=https://auth.example.com/realms/datenschutzagent
# OIDC_CLIENT_ID=datenschutzagent-frontend
# OIDC_CLIENT_SECRET=   (optional, für Confidential Client)
# OIDC_AUDIENCE=   (optional; JWT aud muss übereinstimmen)
# OIDC_SCOPES=openid profile email
# OIDC_ENABLED=false
# RBAC: Default-Rolle für neue Nutzer (erstmaliger OIDC-Login). viewer | editor | admin.
# RBAC_DEFAULT_ROLE=viewer

# ---- Optional: Storage (MinIO) ----
# STORAGE_BACKEND=minio
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=documents
